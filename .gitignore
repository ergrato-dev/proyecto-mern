# =============================================================================
# NN Auth System — MERN
# .gitignore — archivos y carpetas ignorados por git
# =============================================================================

# -----------------------------------------------------------------------------
# Variables de entorno — NUNCA versionar credenciales ni secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Node.js — dependencias
# -----------------------------------------------------------------------------
node_modules/
be/node_modules/
fe/node_modules/

# -----------------------------------------------------------------------------
# Lockfiles — solo pnpm-lock.yaml se versiona; ignorar los de npm/yarn
# -----------------------------------------------------------------------------
package-lock.json
yarn.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# TypeScript — compilación
# -----------------------------------------------------------------------------
be/dist/
fe/dist/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Vite — caché de build
# -----------------------------------------------------------------------------
fe/.vite/

# -----------------------------------------------------------------------------
# Jest / Vitest — cobertura
# -----------------------------------------------------------------------------
coverage/
be/coverage/
fe/coverage/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
be/logs/

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editores e IDEs
# -----------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Docker — datos persistentes locales (no el docker-compose.yml)
# -----------------------------------------------------------------------------
docker-data/

# -----------------------------------------------------------------------------
# Archivos temporales
# -----------------------------------------------------------------------------
*.tmp
*.temp
